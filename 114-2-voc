                                </button>

                                <button onClick={() => generateQuiz('syn-ant')} className="flex items-center gap-5 p-6 bg-white border-2 border-purple-200 rounded-3xl transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                                    <div className="p-4 bg-purple-50 text-purple-600 rounded-2xl"><Icon name="rotate-ccw" /></div>
                                    <div className="text-left">
                                        <h3 className="font-black text-slate-800 text-lg">模式二：近義/反義詞</h3>
                                        <p className="text-slate-500 text-sm">掌握詞彙之間的深層關聯</p>
                                    </div>
                                    <Icon name="chevron-right" className="ml-auto text-slate-300" />
                                </button>

                                <button onClick={() => generateQuiz('sentence')} className="flex items-center gap-5 p-6 bg-white border-2 border-emerald-200 rounded-3xl transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                                    <div className="p-4 bg-emerald-50 text-emerald-600 rounded-2xl"><Icon name="settings" /></div>
                                    <div className="text-left">
                                        <h3 className="font-black text-slate-800 text-lg">模式三：句子填空</h3>
                                        <p className="text-slate-500 text-sm">在語境中精準使用單字</p>
                                    </div>
                                    <Icon name="chevron-right" className="ml-auto text-slate-300" />
                                </button>

                                <button onClick={() => setView('review_all')} className="flex items-center gap-5 p-6 bg-orange-50/30 border-2 border-orange-200 rounded-3xl transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                                    <div className="p-4 bg-orange-100 text-orange-600 rounded-2xl"><Icon name="layers" /></div>
                                    <div className="text-left">
                                        <h3 className="font-black text-orange-800 text-lg">模式四：單字複習卡</h3>
                                        <p className="text-orange-600 text-sm">系統化複習所有單字</p>
                                    </div>
                                    <Icon name="chevron-right" className="ml-auto text-orange-300" />
                                </button>

                                <div className="grid grid-cols-2 gap-4 mt-6">
                                    <button 
                                        onClick={() => wrongQuestions.length > 0 && generateQuiz('zh-en', wrongQuestions)}
                                        className={`flex items-center justify-center gap-2 p-4 rounded-2xl border-2 transition-all ${wrongQuestions.length > 0 ? 'bg-rose-50 border-rose-100 text-rose-700' : 'bg-slate-100 text-slate-300 border-transparent cursor-not-allowed'}`}
                                    >
                                        <Icon name="x-circle" size={18} />
                                        <span className="font-bold">錯題複習 ({wrongQuestions.length})</span>
                                    </button>
                                    <button 
                                        onClick={() => starredIds.length > 0 && generateQuiz('zh-en', VOCAB_DATA.filter(v => starredIds.includes(v.id)))}
                                        className={`flex items-center justify-center gap-2 p-4 rounded-2xl border-2 transition-all ${starredIds.length > 0 ? 'bg-yellow-50 border-yellow-100 text-yellow-700' : 'bg-slate-100 text-slate-300 border-transparent cursor-not-allowed'}`}
                                    >
                                        <Icon name="star" size={18} />
                                        <span className="font-bold">重點標記 ({starredIds.length})</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                );
            }

            if (view === 'review_all') {
                const filteredVocab = VOCAB_DATA.filter(v => 
                    v.category === reviewCategory && 
                    (v.word.toLowerCase().includes(searchTerm.toLowerCase()) || v.zh.includes(searchTerm))
                );

                return (
                    <div className="min-h-screen bg-white flex flex-col">
                        <div className="sticky top-0 z-10 bg-white/80 backdrop-blur-md border-b p-4">
                            <div className="max-w-4xl mx-auto flex items-center gap-4">
                                <button onClick={() => setView('menu')} className="p-2 hover:bg-slate-100 rounded-full transition-colors">
                                    <Icon name="arrow-left" />
                                </button>
                                <h2 className="text-xl font-bold text-slate-800">單字複習卡</h2>
                            </div>
                            <div className="max-w-4xl mx-auto mt-4">
                                <div className="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
                                    {['Unit 7', 'Unit 8', 'TOEIC'].map(cat => (
                                        <button 
                                            key={cat}
                                            onClick={() => setReviewCategory(cat)}
                                            className={`px-6 py-2 rounded-full font-bold whitespace-nowrap transition-all ${reviewCategory === cat ? 'bg-slate-900 text-white shadow-lg shadow-slate-200' : 'bg-slate-100 text-slate-500 hover:bg-slate-200'}`}
                                        >
                                            {cat === 'TOEIC' ? 'TOEIC (Group 1-4)' : cat}
                                        </button>
                                    ))}
                                </div>
                                <div className="relative mt-4">
                                    <div className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"><Icon name="search" size={18} /></div>
                                    <input 
                                        type="text" 
                                        placeholder="搜尋單字或中文..."
                                        className="w-full pl-10 pr-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-slate-200 transition-all"
                                        value={searchTerm}
                                        onChange={(e) => setSearchTerm(e.target.value)}
                                    />
                                </div>
                            </div>
                        </div>

                        <div className="flex-1 max-w-4xl w-full mx-auto p-4 space-y-4">
                            {filteredVocab.map(v => (
                                <div key={v.id} className="p-6 bg-white border border-slate-100 rounded-3xl shadow-sm hover:shadow-md transition-shadow">
                                    <div className="flex justify-between items-start mb-4">
                                        <div>
                                            <div className="flex items-center gap-3">
                                                <h3 className="text-2xl font-black text-slate-900">{v.word}</h3>
                                                <span className="text-xs font-bold text-slate-400 border border-slate-200 px-2 py-0.5 rounded uppercase">{v.type}</span>
                                            </div>
                                            <p className="text-lg font-bold text-blue-600 mt-1">{v.zh}</p>
                                        </div>
                                        <button onClick={() => toggleStar(v.id)} className={`${starredIds.includes(v.id) ? 'text-yellow-500' : 'text-slate-200'} p-2 hover:scale-110 transition-transform`}>
                                            <Icon name="star" fill={starredIds.includes(v.id) ? "currentColor" : "none"} />
                                        </button>
                                    </div>
                                    <div className="space-y-3 bg-slate-50 p-4 rounded-2xl">
                                        <div className="flex gap-2 text-sm">
                                            <span className="font-bold text-slate-400 shrink-0">例句:</span>
                                            <span className="text-slate-600 italic leading-relaxed">{v.sentence}</span>
                                        </div>
                                        
                                        {/* 新增關聯單字顯示區塊 */}
                                        {v.crossRefs && v.crossRefs.length > 0 && (
                                            <div className="mt-4 pt-3 border-t border-slate-200">
                                                <p className="text-xs font-bold text-slate-400 mb-2">本系統內相關單字：</p>
                                                <div className="space-y-1">
                                                    {v.crossRefs.map(refId => {
                                                        const refWord = getVocabById(refId);
                                                        return refWord ? (
                                                            <div key={refId} className="text-sm text-slate-700">
                                                                * {refWord.word} {refWord.zh} ({refWord.category})
                                                            </div>
                                                        ) : null;
                                                    })}
                                                </div>
                                            </div>
                                        )}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                );
            }

            if (view === 'quiz') {
                const q = questions[currentIndex];
                const isStarred = starredIds.includes(q.id);
                return (
                    <div className="min-h-screen bg-white p-6 flex flex-col items-center">
                        <div className="w-full max-w-xl">
                            <div className="flex items-center justify-between mb-8">
                                <button onClick={() => setView('menu')} className="text-slate-400 hover:text-slate-600"><Icon name="arrow-left" /></button>
                                <div className="flex-1 px-8">
                                    <div className="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                        <div className="h-full bg-slate-900 transition-all duration-500" style={{ width: `${((currentIndex + 1) / questions.length) * 100}%` }}></div>
                                    </div>
                                </div>
                                <button onClick={() => toggleStar(q.id)} className={`${isStarred ? 'text-yellow-500' : 'text-slate-200'} transition-colors`}>
                                    <Icon name="star" fill={isStarred ? "currentColor" : "none"} />
                                </button>
                            </div>
                            <div className="text-center mb-10">
                                <span className="text-xs font-black text-slate-300 tracking-widest uppercase">Question {currentIndex + 1} / {questions.length}</span>
                                <div className="mt-4 min-h-[140px] flex items-center justify-center bg-slate-50 rounded-[40px] p-8">
                                    {quizMode === 'zh-en' && <h2 className="text-3xl font-black text-slate-800">{q.zh}</h2>}
                                    {quizMode === 'syn-ant' && <h2 className="text-4xl font-black text-slate-900">{q.word}</h2>}
                                    {quizMode === 'sentence' && <p className="text-xl font-medium text-slate-700 italic">"{q.sentence.replace(new RegExp(q.word, 'gi'), '______')}"</p>}
                                </div>
                            </div>
                            <div className="grid gap-3">
                                {q.options.map((opt) => (
                                    <button 
                                        key={opt.id} 
                                        onClick={() => handleAnswer(opt.id)} 
                                        disabled={showExplanation}
                                        className={`w-full p-5 text-left border-2 rounded-2xl transition-all duration-300 flex justify-between items-center ${
                                            showExplanation 
                                            ? (opt.id === q.id ? "border-emerald-500 bg-emerald-50 text-emerald-700" : (selectedAnswer === opt.id ? "border-rose-500 bg-rose-50 text-rose-700" : "opacity-40"))
                                            : "border-slate-100 hover:border-slate-900 hover:bg-slate-900 hover:text-white"
                                        }`}
                                    >
                                        <span className="text-lg font-bold">{opt.word}</span>
                                        {showExplanation && opt.id === q.id && <Icon name="check-circle-2" size={20} />}
                                        {showExplanation && selectedAnswer === opt.id && opt.id !== q.id && <Icon name="x-circle" size={20} />}
                                    </button>
                                ))}
                            </div>
                            {showExplanation && (
                                <div className="mt-10 p-8 bg-slate-900 text-white rounded-[40px] animate-bounce-short">
                                    <div className="text-2xl font-black mb-2">{q.word}</div>
                                    <div className="text-blue-400 font-bold mb-4">{q.zh}</div>
                                    <p className="text-slate-400 text-sm italic">"{q.sentence}"</p>
                                    <button onClick={nextQuestion} className="w-full mt-8 py-4 bg-white text-slate-900 font-black rounded-2xl">
                                        {currentIndex === questions.length - 1 ? "看總結" : "下一題"}
                                    </button>
                                </div>
                            )}
                        </div>
                    </div>
                );
            }

            if (view === 'result') {
                return (
                    <div className="min-h-screen bg-slate-50 flex items-center justify-center p-6">
                        <div className="max-w-md w-full bg-white p-10 rounded-[50px] shadow-2xl text-center">
                            <div className="w-20 h-20 bg-blue-50 text-blue-600 rounded-3xl flex items-center justify-center mx-auto mb-6 rotate-12"><Icon name="book-marked" size={40} /></div>
                            <h2 className="text-3xl font-black text-slate-900 mb-2">測驗完成！</h2>
                            <div className="flex justify-center gap-4 my-8">
                                <div className="flex-1 p-4 bg-emerald-50 rounded-3xl"><div className="text-emerald-600 font-black text-3xl">{score}</div><div className="text-xs font-bold uppercase">Correct</div></div>
                                <div className="flex-1 p-4 bg-rose-50 rounded-3xl"><div className="text-rose-600 font-black text-3xl">{questions.length - score}</div><div className="text-xs font-bold uppercase">Wrong</div></div>
                            </div>
                            <button onClick={() => setView('menu')} className="w-full py-4 bg-slate-900 text-white font-black rounded-2xl shadow-xl hover:-translate-y-1 transition-all">返回首頁</button>
                        </div>
                    </div>
                );
            }
            return null;
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
