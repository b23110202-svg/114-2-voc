                    const distractors = pool
                        .filter(d => d.id !== v.id)
                        .sort(() => 0.5 - Math.random())
                        .slice(0, 3);
                    const options = [...distractors, v].sort(() => 0.5 - Math.random());
                    return { ...v, options };
                });
                
                setQuestions(selected);
                setCurrentIndex(0);
                setScore(0);
                setQuizMode(mode);
                setView('quiz');
                setSelectedAnswer(null);
                setShowExplanation(false);
